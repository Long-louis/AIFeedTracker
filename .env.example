# 飞书应用配置（必填）
app_id=your_feishu_app_id
app_secret=your_feishu_app_secret

# B站Cookie配置（可选，用于动态监控）
SESSDATA=
bili_jct=
buvid3=
DedeUserID=
DedeUserID__ckMd5=
refresh_token=

# User-Agent配置（可选，使用默认值即可）
USER_AGENT=

# AI总结服务配置（可选）
AI_SERVICE=deepseek
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# 监控配置（可选，使用默认值）
MONITOR_QUIET_START=0
MONITOR_QUIET_END=7
MONITOR_CHECK_INTERVAL=300
