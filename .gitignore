data/feishu_channels.json
data/bilibili_creators.json

# 允许公开示例与说明文件
!data/*.example
!data/README.md

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

