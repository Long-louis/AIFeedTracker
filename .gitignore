# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/
env/

# Playwright
.playwright-mcp/
browser_data/

# Environment and secrets
.env
.env.local
.env.*.local
*.key
*.pem

# Internal development files (keep locally, don't push)
.cursor/
.worktrees/
docs/superpowers/

# Server-local deploy files
deploy/.env
deploy/docker-compose.override.yml

# Scripts directory (keep deployment scripts)
!scripts/

# Test files (root level only, keep tests/ directory)
/test_*.py
/debug_*.py

# Master-branch specific test files (not in open-source)
tests/test_login_auto.py
tests/test_login_stability.py

# Log files
log/
*.log

# Data files (contain runtime state and credentials)
# 忽略运行时状态文件
data/bilibili_state.json
data/*.bak
data/*.tmp
# 但允许示例文件和业务配置文件（私有仓库安全）
!data/*.example
!data/feishu_channels.json
!data/bilibili_creators.json
!data/README.md

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Backup files
backup/
*.bak
*.backup
data/bilibili_auth.json
