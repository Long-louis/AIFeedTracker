# =========================
# 应用运行所需环境变量（复制自根目录 env.example + 你自己的值）
# 下面只放最常见的几项占位；你可以直接把根目录 env.example 的内容粘贴进来。
# =========================

# 飞书卡片模板
FEISHU_TEMPLATE_ID=YOUR_TEMPLATE_ID
FEISHU_TEMPLATE_VERSION=1.0.0

# （可选）如果你的 feishu_channels.json 不在 /app/data/feishu_channels.json
# FEISHU_CHANNELS_CONFIG=/app/data/feishu_channels.json

# AI
AI_SERVICE=deepseek
AI_API_KEY=YOUR_AI_API_KEY
# AI_BASE_URL=
# AI_MODEL=

# （可选）B站 Cookie
# SESSDATA=
# bili_jct=
# buvid3=
# buvid4=
# DedeUserID=
# DedeUserID__ckMd5=
# ac_time_value=
# refresh_token=

# 通用
TZ=Asia/Shanghai
PYTHONUNBUFFERED=1
