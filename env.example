# AI Feed Tracker environment example
# Copy this file to `.env` and fill in your real values.
# Also copy:
#   cp data/feishu_channels.json.example data/feishu_channels.json
#   cp data/bilibili_creators.json.example data/bilibili_creators.json
# No additional private `data/*.json` example files are required.

# Feishu card template settings
FEISHU_TEMPLATE_ID=your-feishu-template-id
FEISHU_TEMPLATE_VERSION=your-feishu-template-version

# Optional: override the channel registry path
# FEISHU_CHANNELS_CONFIG=data/feishu_channels.json

# Bilibili credential settings
SESSDATA=your-sessdata
bili_jct=your-bili-jct
buvid3=your-buvid3
# Optional
# buvid4=your-buvid4
DedeUserID=your-dede-user-id
# Optional legacy field
# DedeUserID__ckMd5=your-dede-user-id-ckmd5
ac_time_value=your-ac-time-value
refresh_token=your-refresh-token

# AI summary settings
AI_SERVICE=deepseek
AI_API_KEY=your-api-key
# Optional
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# Optional local ASR fallback for videos without subtitles
# Set `LOCAL_ASR_ENABLED=false` to disable local ASR fallback entirely.
# `LOCAL_ASR_PROVIDER` currently supports only `sensevoice_api`.
# LOCAL_ASR_ENABLED=false
# LOCAL_ASR_PROVIDER=sensevoice_api
# ASR_API_URL=http://127.0.0.1:8900/v1/transcribe
# ASR_API_TIMEOUT_SECONDS=300
# LOCAL_ASR_TEMP_DIR=./data/temp_asr
# LOCAL_ASR_MAX_AUDIO_MINUTES=90
# LOCAL_ASR_CLEANUP_TEMP_FILES=true

# Optional browser user agent
# USER_AGENT=Mozilla/5.0 ...

# Optional Feishu Docs knowledge-base output for video summaries
# Uses wiki hierarchy: root -> creator -> YYYY-MM -> per-video document
# FEISHU_DOCS_ENABLED=false
# FEISHU_DOCS_APP_ID=your-feishu-app-id
# FEISHU_DOCS_APP_SECRET=your-feishu-app-secret
# FEISHU_DOCS_WIKI_SPACE_ID=your-feishu-wiki-space-id
# Optional: use an existing root node token instead of auto-creating one
# FEISHU_DOCS_ROOT_NODE_TOKEN=
# Optional root title when auto-creating root node
# FEISHU_DOCS_ROOT_TITLE=AI视频知识库
# Optional runtime state path for doc mappings and content hash
# FEISHU_DOCS_STATE_PATH=./data/feishu_doc_state.json
