# ============================================
# AI视频机器人环境配置示例
# ============================================
# 复制此文件为 .env 并填入实际配置

# ============================================
# 飞书机器人配置
# ============================================
# 本项目采用“通道注册表”方式管理多 webhook：
# 1) 复制示例文件：cp data/feishu_channels.json.example data/feishu_channels.json
# 2) 在 data/feishu_channels.json 内填入多个 webhook 的 url/secret，并设置 defaults.content / defaults.alert
# 3) 在 creators 配置里可为不同 UP 指定不同 feishu_channel（例如 webhook:vip）

# 可选：自定义通道注册表文件路径（默认 data/feishu_channels.json）
# FEISHU_CHANNELS_CONFIG=data/feishu_channels.json

# ============================================
# 飞书消息配置
# ============================================
FEISHU_TEMPLATE_ID=your-feishu-template-id
FEISHU_TEMPLATE_VERSION=your-feishu-template-version#
# 可选：如果在 channels registry 中使用 app:<name> 通道，则需要在运行环境安装 lark-oapi
# 并在 channels 配置中填入 app_id 和 app_secret。
# ============================================
# B站配置（用于动态监控）
# ============================================
# 从浏览器 Cookie / LocalStorage 获取以下信息
SESSDATA=your-sessdata
bili_jct=your-bili-jct
buvid3=your-buvid3
# 可选：如果浏览器有 buvid4 也填上，提升成功率
# buvid4=your-buvid4
# DedeUserID 账号 UID，可用 dedeuserid 代替
DedeUserID=your-dede-user-id
# 可选：旧字段，库已不需要，但保留兼容
# DedeUserID__ckMd5=your-dede-user-id-ckmd5
# LocalStorage 中的 ac_time_value，用于 Cookie 刷新
ac_time_value=your-ac-time-value

# 可选：B站刷新令牌（用于自动刷新Cookie）
refresh_token=your-refresh-token

# ============================================
# AI总结服务配置
# ============================================
# 服务选择: deepseek, zhipu, qwen
AI_SERVICE=deepseek

# API密钥（必填）
AI_API_KEY=your-api-key-here

# 可选配置：自定义API地址和模型
# 如果不设置，将根据AI_SERVICE自动选择默认值
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# ============================================
# 其他配置
# ============================================
# User-Agent（可选）
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ============================================
# 各AI服务获取API Key的方法：
# ============================================
# 
# 1. DeepSeek (推荐)
#    网站: https://platform.deepseek.com/
#    模型: deepseek-chat
#    特点: 性价比高，质量好
#    价格: ¥1/百万tokens(输入), ¥2/百万tokens(输出)
#
# 2. 智谱AI (GLM)
#    网站: https://open.bigmodel.cn/
#    模型: glm-4
#    特点: 兼容OpenAI SDK，国产化
#
# 3. 通义千问 (阿里云)
#    网站: https://dashscope.aliyun.com/
#    模型: qwen-turbo, qwen-plus
#    特点: 阿里云生态，稳定可靠
#

